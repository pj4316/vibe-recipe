{
  "hooks": {
    "preToolUse": "./pre-tool-use.mjs",
    "postToolUse": "./post-tool-use.mjs",
    "preCommit": "./pre-commit.mjs",
    "commitMsg": "./commit-msg.mjs",
    "subagentStop": "./subagent-stop.mjs",
    "sessionEnd": "./session-end.mjs"
  },
  "policy": {
    "protectedFiles": [
      ".env",
      ".env.*",
      ".git/**",
      ".agent/constitution.md",
      ".agent/spec/INDEX.md"
    ],
    "dangerousPatterns": [
      "rm -rf /",
      "git reset --hard",
      "git push --force",
      "DROP DATABASE",
      "chmod -R 777"
    ]
  }
}
